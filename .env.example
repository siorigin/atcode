# AtCode Configuration
# Copy to .env and customize


# LOG_LEVEL=INFO
# DEBUG=false
LOG_DIR=./data/logs

# =============================================================================
# Docker / Compose
# =============================================================================
COMPOSE_PROJECT_NAME=atcode
# HOST_UID=1000      # Optional for manual `docker compose`; atcode.sh auto-detects current UID
# HOST_GID=1000      # Optional for manual `docker compose`; atcode.sh auto-detects current GID
# Manual/dev mode also honors ATCODE_DATA_DIR when it is an absolute path.
# Use that if frontend/backend run from different checkouts but must share one data directory.
ATCODE_DATA_DIR=../data
REDIS_DATA_DIR=../data/redis

# =============================================================================
# LLM Configuration (Required)
# =============================================================================
# Supported chat providers:
# - openai-compatible: OpenAI or any OpenAI-compatible /v1 endpoint
# - gemini: Gemini via Google SDK
# - ollama: local Ollama endpoint
#
# Legacy aliases still accepted:
# - openai -> openai-compatible
# - google -> gemini
LLM_PROVIDER=openai-compatible
LLM_MODEL=your-chat-model
LLM_API_KEY=your-chat-api-key
LLM_BASE_URL=  # Optional for openai-compatible or ollama endpoints, e.g. https://your-endpoint/v1

# =============================================================================
# Embedding (Optional - defaults to LLM config if not set)
# =============================================================================
# Supported embedding providers:
# - openai-compatible
# - voyage
# - vllm
#
# Legacy alias still accepted:
# - openai -> openai-compatible
#
# If chat uses gemini or ollama, configure EMBEDDING_* separately
# or build your first graph with skip_embeddings=true.
# EMBEDDING_PROVIDER=openai-compatible
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_BASE_URL=
# EMBEDDING_DIMENSION=1536

REDIS_URL=redis://localhost:6379/0


# =============================================================================
# Server
# =============================================================================
PORT=3007           # Frontend port
API_PORT=8008       # Backend port
# NEXT_PUBLIC_API_URL=http://localhost:8008  # Optional: override auto-derived backend URL (for nginx proxy like /backapi)
# NEXT_PUBLIC_MCP_URL=http://localhost:8008/mcp  # Optional: explicit MCP URL for CLI tools
# ALLOWED_ORIGINS=https://your-domain.com,http://10.96.11.5:3007  # Optional explicit CORS additions
# CORS_ALLOW_PRIVATE_NETWORKS=true  # Default true: allow localhost/private-network browser origins on PORT
# CORS_ALLOW_ALL_ORIGINS=true  # Optional debug escape hatch: allow any http/https browser origin
# OVERVIEW_PROGRESS_TIMEOUT_SECONDS=1800  # Max silence before doc generation is considered stalled
# OVERVIEW_PROGRESS_HEARTBEAT_SECONDS=5  # Heartbeat cadence while child sections are still running
# OVERVIEW_AUTO_RESUME_ON_STALL=true  # Automatically resume once a doc task stalls
# OVERVIEW_AUTO_RESUME_MAX_ATTEMPTS=3  # Max automatic resume attempts for missing sections

# =============================================================================
# Database
# =============================================================================
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
# LAB_PORT=3000        # Memgraph Lab UI port (change if 3000 is occupied)

# =============================================================================
# Security (Change in production!)
# =============================================================================
JWT_SECRET=change-me-in-production
